# App
NODE_ENV=development
PORT=5000
APP_TIMEZONE=America/Phoenix

# Database
DATABASE_URL=postgres://user:password@localhost:5432/protectiveshell

# Sessions and admin login
SESSION_SECRET=replace-with-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-before-production
TRUST_PROXY=0
COOKIE_SECURE=0

# Secret encryption
# Use a stable 32-byte random value encoded as base64 or hex.
SECRET_ENCRYPTION_KEY=replace-with-a-stable-random-key

# Development-only escape hatches for legacy/self-signed infrastructure.
# Leave disabled in production unless each target is otherwise isolated.
ALLOW_INSECURE_TARGET_TLS=0
ALLOW_INSECURE_SSH_HOST_KEYS=0
ALLOW_PRODUCTION_INSECURE_TARGETS=0

# Optional scheduler intervals
SEED_ON_BOOT=0
DISABLE_SCHEDULER=0
PROXMOX_POLL_INTERVAL_MINUTES=5
BACKUP_TARGET_POLL_INTERVAL_MINUTES=30
IMAP_POLL_INTERVAL_MINUTES=60
RETENTION_DAYS=90
LOGIN_RATE_LIMIT_MAX=8

# Optional IMAP/SMTP values can also be stored from the Settings page.
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
IMAP_FOLDER=INBOX
IMAP_TLS=1
IMAP_FETCH_LIMIT=50
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_STARTTLS=1
